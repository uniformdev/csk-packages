{
  "name": "@uniformdev/csk-cli",
  "version": "6.1.82",
  "description": "Command-line interface (CLI) tool designed to streamline the development workflow within Uniform projects. It provides commands for pulling additional data and generating components based on Canvas data",
  "license": "SEE LICENSE IN LICENSE.txt",
  "engines": {
    "node": "^18.18.0 || ^19.8.0 || >= 20.0.0"
  },
  "main": "./cli.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./cli.js"
    },
    "./tailwindcss-conf": {
      "types": "./dist/tailwindcss-conf.d.mts",
      "default": "./dist/tailwindcss-conf.mjs"
    },
    "./components": {
      "types": "./dist/components.d.mts",
      "default": "./dist/components.mjs"
    },
    "./proxy-fetch": {
      "types": "./dist/proxy-fetch.d.mts",
      "default": "./dist/proxy-fetch.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "csk-cli": "node ./cli.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix --rule \"prettier/prettier: error\""
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^14.0.3",
    "dotenv": "17.4.2",
    "ora": "^9.4.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/jest": "^30.0.0",
    "@uniformdev/canvas": "^20.63.0",
    "next": "^16.2.6",
    "prettier": "3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@uniformdev/canvas": "^20.63.0",
    "next": ">=16",
    "prettier": ">=3",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "bin": {
    "csk-cli": "cli.js"
  },
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
