{
  "name": "@uniformdev/csk-components",
  "version": "6.1.88",
  "description": "Components Starter Kit that provides a set of basic components for building websites within a Uniform project",
  "license": "SEE LICENSE IN LICENSE.txt",
  "engines": {
    "node": "^18.18.0 || ^19.8.0 || >= 20.0.0"
  },
  "main": "./cli.js",
  "exports": {
    "./types/cskTypes": {
      "types": "./dist/types/cskTypes.d.mts",
      "default": "./dist/types/cskTypes.mjs"
    },
    "./utils/styling": {
      "types": "./dist/utils/styling.d.mts",
      "default": "./dist/utils/styling.mjs"
    },
    "./utils/routing": {
      "types": "./dist/utils/routing.d.mts",
      "default": "./dist/utils/routing.mjs"
    },
    "./utils/assets": {
      "types": "./dist/utils/assets.d.mts",
      "default": "./dist/utils/assets.mjs"
    },
    "./utils/createEmptyPlaceholderResolver": {
      "types": "./dist/utils/createEmptyPlaceholderResolver.d.mts",
      "default": "./dist/utils/createEmptyPlaceholderResolver.mjs"
    },
    "./utils/createComponentResolver": {
      "types": "./dist/utils/createComponentResolver.d.mts",
      "default": "./dist/utils/createComponentResolver.mjs"
    },
    "./utils/getSlotComponents": {
      "types": "./dist/utils/getSlotComponents.d.mts",
      "default": "./dist/utils/getSlotComponents.mjs"
    },
    "./utils/withSlotsDataValue": {
      "types": "./dist/utils/withSlotsDataValue.d.mts",
      "default": "./dist/utils/withSlotsDataValue.mjs"
    },
    "./utils/withFlattenParameters": {
      "types": "./dist/utils/withFlattenParameters.d.mts",
      "default": "./dist/utils/withFlattenParameters.mjs"
    },
    "./utils/sitemap": {
      "types": "./dist/utils/sitemap.d.mts",
      "default": "./dist/utils/sitemap.mjs"
    },
    "./components/ui": {
      "types": "./dist/components/ui/index.d.mts",
      "default": "./dist/components/ui/index.mjs"
    },
    "./components/canvas": {
      "types": "./dist/components/canvas/index.d.mts",
      "default": "./dist/components/canvas/index.mjs"
    },
    "./components/canvas/serverOnly": {
      "types": "./dist/components/canvas/serverOnly.d.mts",
      "default": "./dist/components/canvas/serverOnly.mjs"
    },
    "./components/canvas/serverClient": {
      "types": "./dist/components/canvas/serverClient.d.mts",
      "default": "./dist/components/canvas/serverClient.mjs"
    },
    "./components/canvas/emptyPlaceholders": {
      "types": "./dist/components/canvas/emptyPlaceholders.d.mts",
      "default": "./dist/components/canvas/emptyPlaceholders.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "csk-components": "node ./cli.js",
    "build:tsup": "tsup",
    "postbuild": "tsx ./src/scripts/copy-content.tsx",
    "build": "npm run build:tsup && npm run postbuild",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix --rule \"prettier/prettier: error\""
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "@types/react-responsive-masonry": "^2.7.0",
    "classnames": "^2.5.1",
    "commander": "^14.0.3",
    "cookies-next": "^6.1.1",
    "dotenv": "17.4.2",
    "js-cookie": "^3.0.7",
    "ora": "^9.4.0",
    "prettier": "3.8.3",
    "react-player": "^3.4.0",
    "react-responsive-masonry": "^2.7.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.9.1",
    "@uniformdev/assets": "^20.65.0",
    "@uniformdev/canvas": "^20.65.0",
    "@uniformdev/next-app-router": "^20.65.0",
    "@uniformdev/next-app-router-client": "^20.65.0",
    "@uniformdev/next-app-router-shared": "^20.65.0",
    "@uniformdev/project-map": "^20.65.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3"
  },
  "peerDependencies": {
    "@uniformdev/assets": "^20.65.0",
    "@uniformdev/canvas": "^20.65.0",
    "@uniformdev/next-app-router": "^20.65.0",
    "@uniformdev/next-app-router-client": "^20.65.0",
    "@uniformdev/next-app-router-shared": "^20.65.0",
    "@uniformdev/project-map": "^20.65.0",
    "next": ">=16",
    "next-themes": ">=0.4.0",
    "react": ">=19",
    "react-dom": ">=19",
    "tailwindcss": ">=3"
  },
  "bin": {
    "csk-components": "cli.js"
  },
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
