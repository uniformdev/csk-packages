{
  "name": "@uniformdev/csk-marketing-site",
  "version": "6.1.81",
  "private": true,
  "engines": {
    "yarn": "please-use-npm",
    "pnpm": "please-use-npm",
    "node": "^18.18.0 || ^19.8.0 || >= 20.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "run-s pull:dex apply:dex pull:locales next:dev",
    "build": "cross-env NODE_ENV=production run-s pull:locales pull:dex apply:dex next:build",
    "start": "next start",
    "dev:watch": "cross-env WATCH=true run-s pull:dex apply:dex next:dev",
    "next:dev": "next dev",
    "next:build": "next build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "init": "run-s uniform:push uniform:publish",
    "component:extract": "csk-components extract",
    "component:scaffold": "csk-cli scaffold",
    "pull:dex": "design-extensions-tools pull",
    "apply:dex": "design-extensions-tools apply",
    "pull:additional": "uniform sync pull",
    "push:dex": "design-extensions-tools push",
    "push:content": "run-s push:base push:additional",
    "push:base": "uniform sync push --config ./uniform_base.config.ts",
    "push:additional": "uniform sync push --config ./uniform_additional.config.ts",
    "pull:locales": "csk-cli pull -l",
    "sync:category": "tsx ./src/scripts/sync_canvas_cache.ts category ./content/category equals",
    "sync:component": "tsx ./src/scripts/sync_canvas_cache.ts component ./content/component",
    "uniform:pull": "run-s pull:dex apply:dex pull:additional sync:category sync:component",
    "uniform:push": "run-s push:dex push:content",
    "uniform:publish": "uniform context manifest publish",
    "make-components-preview": "tsx ./src/scripts/make-preview-images.ts"
  },
  "dependencies": {
    "@uniformdev/assets": "^20.63.0",
    "@uniformdev/canvas": "^20.63.0",
    "@uniformdev/context": "^20.63.0",
    "@uniformdev/csk-components": "*",
    "@uniformdev/design-extensions-tools": "*",
    "@uniformdev/next-app-router": "^20.63.0",
    "@uniformdev/next-app-router-client": "^20.63.0",
    "@uniformdev/next-app-router-shared": "^20.63.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@uniformdev/cli": "^20.63.0",
    "@uniformdev/csk-cli": "*",
    "cross-env": "^10.1.0",
    "eslint": "^9.31.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "prettier": "3.8.3",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
